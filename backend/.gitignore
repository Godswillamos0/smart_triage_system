# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables — never commit secrets
.env
.env.*
!.env.example

# Python bytecode & cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# Build / distribution
build/
dist/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Local databases (SQLite used for dev testing)
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# OS generated files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*.DS_Store

# Alembic (if migrations are added later)
# Keep alembic.ini and versions/ but ignore local state
alembic/versions/__pycache__/
